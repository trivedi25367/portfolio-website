DJANGO_SECRET_KEY=change-this-to-a-long-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Contact form email. Leave EMAIL_BACKEND as console while developing.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=
CONTACT_RECIPIENT_EMAIL=

# Optional, only if npm is not available on PATH.
NPM_BIN_PATH=npm
